PORT=3001

# AI Provider Settings
# Options: deepseek (default), groq
AI_PROVIDER=deepseek

# DeepSeek API Key (default AI provider)
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here

# Groq API Key (fallback provider)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# Anthropic API Key (optional - for advanced features)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# FEC API Key
# Get yours at: https://api.open.fec.gov/
FEC_API_KEY=DEMO_KEY

# Database Configuration (defaults work with docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

POSTGRES_URI=postgresql://postgres:password@localhost:5432/unredacted

REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
