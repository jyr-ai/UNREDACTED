PORT=3001

# ─── AI Provider Selection ────────────────────────────────────────────────────
# Choose the active AI provider. Options:
#   deepseek  — DeepSeek Chat (best value, OpenAI-compatible)
#   openai    — OpenAI GPT-4o / GPT-4-turbo
#   anthropic — Anthropic Claude 3.5 Sonnet
#   groq      — Groq (ultra-fast Llama 3.3 70B, free tier available)
#   ollama    — Local Ollama (runs completely offline, no key needed)
#   qwen      — Alibaba Qwen 2.5 (OpenAI-compatible, strong multilingual)
#   xai       — xAI Grok
AI_PROVIDER=deepseek

# Optionally override the default model for the chosen provider:
# AI_MODEL=deepseek-chat

# ─── DeepSeek ────────────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/
# Default model: deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_key_here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Default model: gpt-4o
OPENAI_API_KEY=your_openai_key_here

# ─── Anthropic Claude ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
# Default model: claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Groq (free tier available) ──────────────────────────────────────────────
# Get your key at: https://console.groq.com/
# Default model: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_key_here

# ─── Alibaba Qwen ────────────────────────────────────────────────────────────
# Get your key at: https://dashscope.aliyuncs.com/
# Default model: qwen-plus
QWEN_API_KEY=your_qwen_key_here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ─── xAI Grok ────────────────────────────────────────────────────────────────
# Get your key at: https://console.x.ai/
# Default model: grok-beta
XAI_API_KEY=your_xai_key_here

# ─── Ollama (local — no key required) ────────────────────────────────────────
# Install Ollama: https://ollama.com/
# Run locally:   ollama serve && ollama pull llama3.2
# Default model: llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ─── Government Data API Keys ────────────────────────────────────────────────
# FEC (Federal Election Commission) Campaign Finance API
#
# DEMO_KEY limits: 1,000 requests/day, 30 requests/hour — hits quickly with AI agents.
# Registered key:  1,000 requests/hour — required for production use.
#
# Sign up FREE at: https://api.data.gov/signup/
# (The openFEC API is hosted via api.data.gov — one key works for all data.gov APIs)
#
# After signing up, replace DEMO_KEY below with your registered key:
FEC_API_KEY=DEMO_KEY

# ─── Database Configuration (defaults work with docker-compose) ──────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

POSTGRES_URI=postgresql://postgres:password@localhost:5432/unredacted

REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ─── Gas Price APIs ───────────────────────────────────────────────────────────
# EIA (Energy Information Administration) — free, weekly state gas prices
# Sign up at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# MyGasFeed — free, station-level prices by lat/lng or ZIP
# Request at: http://www.mygasfeed.com/keys/app/request
MYGASFEED_API_KEY=your_mygasfeed_api_key_here

# Google Geocoding API — optional, improves city/ZIP → lat/lng accuracy
# Enable "Geocoding API" in Google Cloud Console → add key below
GOOGLE_GEOCODING_API_KEY=your_google_api_key_here

# Cache TTLs in seconds (defaults shown)
STATE_PRICES_CACHE_TTL=900
NATIONAL_AVG_CACHE_TTL=900
STATIONS_CACHE_TTL=300

# ─── Phase 3: FastAPI Agent Service URL ──────────────────────────────────────
# URL to the Python FastAPI agent service (corruption_agent, policy_agent)
FASTAPI_URL=http://localhost:8000
