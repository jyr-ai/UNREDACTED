# ═══════════════════════════════════════════════════════════════════════════
# UNREDACTED — Unified Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── FEC (Federal Election Commission) ────────────────────────────────────────
# DEMO_KEY limits: 1,000 requests/day, 30 requests/hour — hits quickly with AI agents.
# Registered key:  1,000 requests/hour — required for production use.
# Sign up FREE at: https://api.data.gov/signup/
# (One key works for all data.gov APIs including openFEC)
FEC_API_KEY=DEMO_KEY

# ── AI Provider (choose one) ─────────────────────────────────────────────────
# Options: deepseek | openai | anthropic | groq | ollama | qwen | xai
AI_PROVIDER=deepseek
AI_MODEL=

# DeepSeek (recommended — fast, cheap, OpenAI-compatible)
DEEPSEEK_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Groq (fastest inference, free tier available)
GROQ_API_KEY=

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Alibaba Qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# xAI Grok
XAI_API_KEY=

# ── Optional: Supabase (auth, watchlists, alerts, score caching) ──────────────
# Without these, the app runs fine — auth features are just disabled.
# Create a free project at https://supabase.com to get these values.
# Frontend (VITE_ prefix required for Vite to expose to browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Backend (service role key — never expose to frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: Vercel KV / Upstash Redis (graph query caching) ────────────────
# Set these in your Vercel dashboard → Storage → KV to enable distributed caching.
# Without these, the app uses in-memory caching (works fine, resets on cold start).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Optional: FastAPI AI Agent Service ───────────────────────────────────────
# Only needed if running the Python AI agent service separately.
AI_AGENT_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8000
