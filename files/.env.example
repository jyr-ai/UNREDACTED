# ─── Server ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── EIA API (free) ────────────────────────────────────
# Register at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ─── MyGasFeed API ─────────────────────────────────────
# Register at: http://www.mygasfeed.com/keys/app/request
MYGASFEED_API_KEY=your_mygasfeed_api_key_here

# ─── Google Geocoding API (optional) ───────────────────
# Used to convert city/ZIP → lat/lng for station search
# Enable "Geocoding API" in Google Cloud Console
GOOGLE_GEOCODING_API_KEY=your_google_api_key_here

# ─── Cache TTLs (seconds) ──────────────────────────────
STATE_PRICES_CACHE_TTL=900    # 15 minutes — EIA updates weekly
STATIONS_CACHE_TTL=300        # 5 minutes  — crowd-sourced, changes faster
NATIONAL_AVG_CACHE_TTL=900   # 15 minutes
